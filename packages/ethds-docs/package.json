{
  "name": "ethds-docs",
  "version": "0.1.0",
  "private": true,
  "description": "ETHDS documentation platform (Docusaurus).",
  "scripts": {
    "tokens": "npm run build -w @ethds/tokens && npm run build -w @ethds/react",
    "start": "npm run tokens && docusaurus start",
    "build": "npm run tokens && docusaurus build",
    "serve": "docusaurus serve",
    "clear": "docusaurus clear",
    "write-translations": "docusaurus write-translations",
    "typecheck": "tsc"
  },
  "dependencies": {
    "@docusaurus/core": "^3.10.0",
    "@ethds/react": "^0.1.0",
    "@docusaurus/preset-classic": "^3.10.0",
    "@easyops-cn/docusaurus-search-local": "^0.55.0",
    "@mdx-js/react": "^3.0.0",
    "clsx": "^2.1.0",
    "prism-react-renderer": "^2.4.0",
    "react": "^18.3.0",
    "react-dom": "^18.3.0"
  },
  "devDependencies": {
    "@docusaurus/module-type-aliases": "^3.10.0",
    "@docusaurus/tsconfig": "^3.10.0",
    "@docusaurus/types": "^3.10.0",
    "typescript": "^5.6.0"
  },
  "browserslist": {
    "production": [">0.5%", "not dead", "not op_mini all"],
    "development": ["last 3 chrome version", "last 3 firefox version", "last 5 safari version"]
  },
  "engines": {
    "node": ">=20"
  }
}
