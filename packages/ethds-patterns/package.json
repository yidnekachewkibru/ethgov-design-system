{
  "name": "@ethds/patterns",
  "version": "0.1.0",
  "description": "ETHDS government service patterns — tested React compositions of @ethds/react.",
  "license": "MIT",
  "type": "module",
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./styles.css": "./dist/ethds-patterns.css"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "sideEffects": [
    "*.css"
  ],
  "scripts": {
    "build": "vite build",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "storybook": "storybook dev -p 6007",
    "build-storybook": "storybook build"
  },
  "peerDependencies": {
    "react": ">=18",
    "react-dom": ">=18"
  },
  "dependencies": {
    "@ethds/react": "^0.1.0",
    "@ethds/tokens": "^0.1.0"
  },
  "devDependencies": {
    "@storybook/react": "^8.4.0",
    "@storybook/react-vite": "^8.4.0",
    "@testing-library/jest-dom": "^6.6.0",
    "@testing-library/react": "^16.1.0",
    "@testing-library/user-event": "^14.5.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.0",
    "eslint-plugin-jsx-a11y": "^6.10.0",
    "jsdom": "^25.0.0",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "storybook": "^8.4.0",
    "typescript": "^5.6.0",
    "vite": "^5.4.0",
    "vite-plugin-dts": "^4.3.0",
    "vitest": "^2.1.0",
    "vitest-axe": "^0.1.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/yidnekachewkibru/ethgov-design-system.git",
    "directory": "packages/ethds-patterns"
  },
  "publishConfig": {
    "access": "public"
  }
}
