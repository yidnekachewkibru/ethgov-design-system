{
  "name": "@ethds/tokens",
  "version": "0.1.0",
  "description": "ETHDS design tokens — the source of truth for ETHDS design decisions, built to CSS, TypeScript, and Tailwind.",
  "license": "MIT",
  "type": "module",
  "files": [
    "dist",
    "tokens"
  ],
  "exports": {
    ".": {
      "types": "./dist/tokens.d.ts",
      "import": "./dist/tokens.js"
    },
    "./css": "./dist/tokens.css",
    "./tailwind": "./dist/tailwind.cjs",
    "./tokens.json": "./dist/tokens.json"
  },
  "main": "./dist/tokens.js",
  "types": "./dist/tokens.d.ts",
  "sideEffects": [
    "*.css"
  ],
  "scripts": {
    "build": "node scripts/build.mjs",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "npm run build"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/yidnekachewkibru/ethgov-design-system.git",
    "directory": "packages/ethds-tokens"
  },
  "publishConfig": {
    "access": "public"
  },
  "devDependencies": {
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  }
}
